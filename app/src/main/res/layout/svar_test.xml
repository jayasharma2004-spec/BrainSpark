<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/svartest"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- ================= READING ================= -->
        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15:00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/holo_blue_dark"
            android:layout_marginTop="16dp"
            android:layout_gravity="center"/>
        <LinearLayout
            android:id="@+id/layoutRead"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Reading Test"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvReadSentence"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:textSize="18sp"
                android:textColor="@android:color/black"
                android:gravity="center"
                android:padding="10dp" />

            <Button
                android:id="@+id/btnReadSpeak"
                android:layout_width="150dp"
                android:layout_height="50dp"
                android:text="Speak"
                android:layout_gravity="center_horizontal" />
        </LinearLayout>

        <!-- ================= LISTENING ================= -->
        <LinearLayout
            android:id="@+id/layoutListen"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Listening Test"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:gravity="center" />

            <Button
                android:id="@+id/btnPlayAudio"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:text="Play Sentence"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp" />

            <Button
                android:id="@+id/btnListenSpeak"
                android:layout_width="200dp"
                android:layout_height="50dp"
                android:text="Repeat Sentence"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp" />
        </LinearLayout>

        <!-- ================= JUMBLE ================= -->
        <LinearLayout
            android:id="@+id/layoutJumble"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Jumbled Sentence"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvJumble"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:textSize="18sp"
                android:textColor="@android:color/black"
                android:gravity="center"
                android:padding="10dp" />

            <Button
                android:id="@+id/btnJumbleSpeak"
                android:layout_width="220dp"
                android:layout_height="50dp"
                android:text="Speak Correct Sentence"
                android:layout_gravity="center_horizontal" />
        </LinearLayout>

        <!-- ================= NEXT BUTTON ================= -->
        <Button
            android:id="@+id/btnNext"
            android:layout_width="180dp"
            android:layout_height="55dp"
            android:text="Next"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="30dp" />

    </LinearLayout>
</ScrollView>
